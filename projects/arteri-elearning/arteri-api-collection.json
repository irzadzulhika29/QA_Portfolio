{
  "info": {
    "name": "Arteri E-Learning API",
    "description": "API Testing Collection untuk Arteri E-Learning (Stuudi)\nBase URL: https://be.stuudi.com/api/v1 (ganti sesuai environment)\n\nAuth: Bearer token (JWT) untuk endpoint yang memerlukan login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@arteri.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"User Baru\",\n  \"email\": \"user@test.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ]
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/password/email",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "password",
                "email"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/refresh-token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh-token"
              ]
            }
          }
        }
      ]
    },
