</tr>
<tr>
<td>S-C-02</td>
<td>Aktifkan selection form</td>
<td>Toggle selection enabled</td>
<td>Form builder pertanyaan muncul</td>
</tr>
<tr>
<td>S-C-03</td>
<td>Tambah pertanyaan selection</td>
