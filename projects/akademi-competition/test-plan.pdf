<td>Validasi error "Minimal 1 pertanyaan"</td>
</tr>
<tr>
<td>S-C-07</td>
<td>Validasi - pertanyaan kosong</td>
<td>Tambah pertanyaan tanpa text</td>
<td>Validasi error</td>
</tr>
<tr>
<td>S-C-08</td>
<td>Hapus pertanyaan</td>
<td>Hapus salah satu pertanyaan</td>
<td>Pertanyaan terhapus dari list</td>
</tr>
<tr>
<td>S-C-09</td>
<td>Reorder pertanyaan</td>
<td>Drag &amp; drop urutan</td>
<td>Urutan berubah</td>
</tr>
<tr>
<td>S-C-10</td>
<td>Nonaktifkan selection</td>
<td>Toggle off</td>
<td>Form builder hilang, data selection tidak ikut terkirim</td>
</tr>
<tr>
<td>S-C-11</td>
<td>Edit selection (update)</td>
<td>Edit bootcamp, lihat selection form</td>
<td>Data selection yang sudah ada muncul</td>
</tr>
<tr>
<td>S-C-12</td>
<td>User registrasi dengan selection</td>
<td>User daftar bootcamp dengan selection</td>
<td>Form seleksi muncul sebelum konfirmasi</td>
</tr>
</tbody>
</table>
